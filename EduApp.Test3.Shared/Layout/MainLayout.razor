@code {
    private bool isNavOpen = false;
    private bool isDarkMode = true; 
    private string ThemeClass => isDarkMode ? "dark" : "";
    
    public bool isModalOpen = false;
    public int modalStep = 1; 
    public string selectedSubject = "";
    public string selectedTopic = "";
    public string selectedMode = "";
    public int questionLimit = 10;
    public List<string> availableTopics = new();
    
    private bool showLevelUpModal = false;
    private int newLevelToShow = 0;

    protected override async Task OnInitializedAsync()
    {
        if (!UserState.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
        }
        UserState.OnChange += StateHasChanged;
        UserState.OnLevelUp += HandleLevelUp;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var theme = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "theme");
            if (theme == "light")
            {
                isDarkMode = false;
                StateHasChanged();
            }
        }
    }

    private async Task ToggleTheme()
    {
        isDarkMode = !isDarkMode;
        await JSRuntime.InvokeVoidAsync("localStorage.setItem", "theme", isDarkMode ? "dark" : "light");
    }

    public void Dispose()
    {
        UserState.OnChange -= StateHasChanged;
        UserState.OnLevelUp -= HandleLevelUp;
    }

    private void HandleLevelUp(int newLevel)
    {
        newLevelToShow = newLevel;
        showLevelUpModal = true;
        InvokeAsync(StateHasChanged);
    }

    private void CloseLevelUpModal()
    {
        showLevelUpModal = false;
    }

    private void ToggleNav() => isNavOpen = !isNavOpen;
    private void CloseNav() => isNavOpen = false;

    private void HandleLogout()
    {
        UserState.Logout();
        Navigation.NavigateTo("/login");
    }
    
    public async Task StartSelection(string subject) {
        selectedSubject = subject; 
        modalStep = 1; 
        isModalOpen = true; 
        availableTopics.Clear(); 
        try {
            var connString = Configuration.GetConnectionString("MyDb");
            using var connection = new NpgsqlConnection(connString);
            var topics = await connection.QueryAsync<string>("SELECT DISTINCT topic FROM learning_questions WHERE subject = @Subject", new { Subject = subject });
            availableTopics = topics.ToList();
        } catch (Exception) { availableTopics = new List<string>(); }
        StateHasChanged();
    }

    public void StartExamSelectionCZ() { 
        selectedSubject = "Český jazyk"; 
        modalStep = 9; 
        isModalOpen = true; 
        StateHasChanged();
    }
    
    public void StartExamSelectionAJ() { 
        selectedSubject = "Anglický jazyk"; 
        modalStep = 9; 
        isModalOpen = true; 
        StateHasChanged();
    }
    
    public void StartExamSelectionMAT() { 
        selectedSubject = "Matematika"; 
        modalStep = 9; 
        isModalOpen = true; 
        StateHasChanged();
    }
    
    public void SelectTopic(string topic) { selectedTopic = topic; modalStep = 2; StateHasChanged(); }
    public void SelectMode(string mode) { selectedMode = mode; modalStep = 3; StateHasChanged(); }
    
    public void StartLearning() {
        var limitParam = questionLimit > 0 ? $"/{questionLimit}" : "";
        Navigation.NavigateTo($"/{selectedMode}/{selectedSubject}/{selectedTopic}{limitParam}");
        CloseModal();
    }
    
    public void CloseModal() { isModalOpen = false; modalStep = 1; StateHasChanged(); }
}