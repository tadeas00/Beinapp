@code {
    private bool isNavOpen = false;
    private bool isDarkMode = true; 
    private string ThemeClass => isDarkMode ? "dark" : "";

    // MODÁLNÍ LOGIKA
    public bool isModalOpen = false;
    public int modalStep = 1; 
    public string selectedSubject = "";
    public string selectedTopic = "";
    public string selectedMode = "";
    public int questionLimit = 10;
    public List<string> availableTopics = new();

    // Logika pro zkoušky a jejich skóre
    public string selectedExamLevel = "";
    public int selectedExamYear = 2025;
    public string selectedTestId = "";
    public bool useTimeLimit = true;
    
    private Dictionary<string, int> userExamScores = new();

    private bool showLevelUpModal = false;
    private int newLevelToShow = 0;

    // DYNAMICKÁ TÉMATA
    private class ExamTheme {
        public string BgLight { get; set; } = "";
        public string Text { get; set; } = "";
        public string TextDark { get; set; } = "";
        public string Border { get; set; } = "";
        public string BgMain { get; set; } = "";
        public string Btn { get; set; } = "";
        public string Shadow { get; set; } = "";
        public string HoverText { get; set; } = "";
        public string HoverBg { get; set; } = "";
        public string HoverBorder { get; set; } = "";
        public string HoverBgContainer { get; set; } = "";
        public string ActiveTestBorder { get; set; } = "";
    }

    private ExamTheme CurrentTheme => selectedSubject switch {
        "Anglický jazyk" => new ExamTheme {
            BgLight = "bg-sky-100 dark:bg-sky-500/20",
            Text = "text-sky-500 dark:text-sky-400",
            TextDark = "text-sky-700 dark:text-sky-300",
            Border = "border-sky-200 dark:border-sky-500/30",
            BgMain = "bg-sky-500",
            Btn = "bg-sky-600 hover:bg-sky-500 shadow-sky-500/20",
            Shadow = "shadow-sky-500/40",
            HoverText = "group-hover:text-sky-600 dark:group-hover:text-sky-400",
            HoverBg = "group-hover:bg-sky-500 group-hover:text-white",
            HoverBorder = "hover:border-sky-400 dark:hover:border-sky-500",
            HoverBgContainer = "hover:bg-sky-50 dark:hover:bg-sky-900/20",
            ActiveTestBorder = "border border-[rgba(14,165,233,0.3)] dark:border-[rgba(14,165,233,0.3)]"
        },
        "Matematika" => new ExamTheme {
            BgLight = "bg-blue-100 dark:bg-blue-500/20",
            Text = "text-blue-500 dark:text-blue-400",
            TextDark = "text-blue-700 dark:text-blue-300",
            Border = "border-blue-200 dark:border-blue-500/30",
            BgMain = "bg-blue-500",
            Btn = "bg-blue-600 hover:bg-blue-500 shadow-blue-500/20",
            Shadow = "shadow-blue-500/40",
            HoverText = "group-hover:text-blue-600 dark:group-hover:text-blue-400",
            HoverBg = "group-hover:bg-blue-500 group-hover:text-white",
            HoverBorder = "hover:border-blue-400 dark:hover:border-blue-500",
            HoverBgContainer = "hover:bg-blue-50 dark:hover:bg-blue-900/20",
            ActiveTestBorder = "border border-[rgba(59,130,246,0.3)] dark:border-[rgba(59,130,246,0.3)]"
        },
        _ => new ExamTheme { // Český jazyk (výchozí)
            BgLight = "bg-rose-100 dark:bg-rose-500/20",
            Text = "text-rose-500 dark:text-rose-400",
            TextDark = "text-rose-700 dark:text-rose-300",
            Border = "border-rose-200 dark:border-rose-500/30",
            BgMain = "bg-rose-500",
            Btn = "bg-rose-600 hover:bg-rose-500 shadow-rose-500/20",
            Shadow = "shadow-rose-500/40",
            HoverText = "group-hover:text-rose-600 dark:group-hover:text-rose-400",
            HoverBg = "group-hover:bg-rose-500 group-hover:text-white",
            HoverBorder = "hover:border-rose-400 dark:hover:border-rose-500",
            HoverBgContainer = "hover:bg-rose-50 dark:hover:bg-rose-900/20",
            ActiveTestBorder = "border border-[rgba(244,63,94,0.3)] dark:border-[rgba(244,63,94,0.3)]"
        }
    };

    protected override async Task OnInitializedAsync()
    {
        if (!UserState.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
        }
        UserState.OnChange += StateHasChanged;
        UserState.OnLevelUp += HandleLevelUp;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var theme = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "theme");
            if (theme == "light")
            {
                isDarkMode = false;
                StateHasChanged();
            }
        }
    }

    private async Task ToggleTheme()
    {
        isDarkMode = !isDarkMode;
        await JSRuntime.InvokeVoidAsync("localStorage.setItem", "theme", isDarkMode ? "dark" : "light");
    }

    public void Dispose()
    {
        UserState.OnChange -= StateHasChanged;
        UserState.OnLevelUp -= HandleLevelUp;
    }

    private void HandleLevelUp(int newLevel)
    {
        newLevelToShow = newLevel;
        showLevelUpModal = true;
        InvokeAsync(StateHasChanged);
    }

    private void CloseLevelUpModal() => showLevelUpModal = false;
    private void ToggleNav() => isNavOpen = !isNavOpen;
    private void CloseNav() => isNavOpen = false;

    private void HandleLogout()
    {
        UserState.Logout();
        Navigation.NavigateTo("/login");
    }

    public async Task StartSelection(string subject) {
        selectedSubject = subject; 
        modalStep = 1; 
        isModalOpen = true; 
        availableTopics.Clear(); 
        try {
            var connString = Configuration.GetConnectionString("MyDb");
            using var connection = new NpgsqlConnection(connString);
            var topics = await connection.QueryAsync<string>("SELECT DISTINCT topic FROM learning_questions WHERE subject = @Subject", new { Subject = subject });
            availableTopics = topics.ToList();
        } catch (Exception) { availableTopics = new List<string>(); }
        StateHasChanged();
    }

    // Tady jsou metody volané z Home.razor:
    public void StartExamSelectionCZ() => StartExamSelection("Český jazyk");
    public void StartExamSelectionAJ() => StartExamSelection("Anglický jazyk");
    public void StartExamSelectionMAT() => StartExamSelection("Matematika");

    public void StartExamSelection(string subject) {
        selectedSubject = subject;
        
        // PŘESKOČENÍ KROKU 9 PRO AJ (MÁ JEN MATURITU)
        if (subject == "Anglický jazyk") {
            selectedExamLevel = "Maturita";
            modalStep = 10;
        } else {
            modalStep = 9;
        }
        
        isModalOpen = true;
        StateHasChanged();
    }

    public void SetExamLevel(string level) {
        selectedExamLevel = level;
        modalStep = 10;
        StateHasChanged();
    }

    public async Task SetExamYear(int year) {
        selectedExamYear = year;
        userExamScores = await UserState.GetUserExamScoresAsync();
        modalStep = 11;
        StateHasChanged();
    }

    public void GoToExamSettings(string testId) {
        selectedTestId = testId;
        useTimeLimit = true;
        modalStep = 12;
        StateHasChanged();
    }

    public void StartExamFinal() {
        string subjCode = selectedSubject switch {
            "Český jazyk" => "cj",
            "Anglický jazyk" => "aj",
            "Matematika" => "mat",
            _ => "cj"
        };
        
        int timeLimitInMinutes = useTimeLimit ? (selectedExamLevel == "Přijímačky" ? 60 : 85) : 0;
        
        CloseModal();
        Navigation.NavigateTo($"/exam/{subjCode}/{selectedTestId}?timeLimit={timeLimitInMinutes}");
    }

    public void SelectTopic(string topic) { selectedTopic = topic; modalStep = 2; StateHasChanged(); }
    public void SelectMode(string mode) { selectedMode = mode; modalStep = 3; StateHasChanged(); }
    
    public void StartLearning() {
        var limitParam = questionLimit > 0 ? $"/{questionLimit}" : "";
        Navigation.NavigateTo($"/{selectedMode}/{selectedSubject}/{selectedTopic}{limitParam}");
        CloseModal();
    }
    
    public void CloseModal() { isModalOpen = false; modalStep = 1; StateHasChanged(); }
}