@page "/flashcards/{SubjectName}/{TopicName}"
@page "/flashcards/{SubjectName}/{TopicName}/{Limit:int}"
@using Dapper
@using Npgsql
@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject UserState UserState

<div @ref="mainContainer" 
     @onkeydown="HandleKeyDown" 
     tabindex="0" 
     class="fixed inset-0 z-[100] bg-slate-50 dark:bg-slate-950 flex flex-col font-outfit overflow-hidden outline-none transition-colors duration-500">
    
    <div class="fixed inset-0 z-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-indigo-200 dark:from-indigo-500/10 via-transparent to-transparent"></div>
    
    <nav class="relative z-10 flex items-center justify-between p-4 md:p-6 border-b border-slate-200 dark:border-white/5 bg-white/50 dark:bg-slate-900/50 backdrop-blur-md transition-colors">
        <div class="flex items-center gap-4">
            <button @onclick="@(() => Navigation.NavigateTo("/"))" class="w-10 h-10 rounded-full flex items-center justify-center bg-slate-200/50 dark:bg-white/5 hover:bg-slate-300/50 dark:hover:bg-white/10 text-slate-700 dark:text-white transition">
                <i class="ph ph-x text-xl"></i>
            </button>
            <div>
                <h1 class="text-slate-900 dark:text-white font-bold text-sm md:text-base uppercase tracking-tight">Kartičky: @SubjectName</h1>
                <p class="text-[10px] text-indigo-600 dark:text-indigo-400 font-bold uppercase tracking-widest">Téma: @TopicName</p>
            </div>
        </div>
        <div class="flex items-center gap-3">
             <div class="hidden md:flex gap-1 mr-4">
                 <kbd class="px-2 py-1 bg-white dark:bg-white/5 border border-slate-300 dark:border-white/10 rounded text-[9px] text-slate-500 uppercase shadow-sm dark:shadow-none">Space</kbd>
                 <kbd class="px-2 py-1 bg-white dark:bg-white/5 border border-slate-300 dark:border-white/10 rounded text-[9px] text-slate-500 uppercase shadow-sm dark:shadow-none">← →</kbd>
             </div>
             <span class="text-xs font-bold text-slate-500 uppercase tracking-widest mr-2">@(currentIndex + 1) / @questions.Count</span>
             <div class="w-10 h-10 rounded-xl bg-amber-100 dark:bg-amber-500/20 flex items-center justify-center text-amber-600 dark:text-amber-400">
                <i class="ph ph-cards text-xl"></i>
            </div>
        </div>
    </nav>
    
    <div class="relative z-10 flex-grow flex flex-col items-center justify-center p-6">
        
        @if (isLoading)
        {
            <div class="text-center">
                <i class="ph ph-spinner animate-spin text-5xl text-indigo-500 mb-4"></i>
                <p class="text-slate-500 dark:text-slate-400 uppercase tracking-widest text-[10px]">Míchám kartičky...</p>
            </div>
        }
        else if (questions.Any() && !isFinished)
        {
            <div class="perspective-container w-full max-w-lg aspect-[3/4] md:aspect-[4/3] @cardAnimationClass" @onclick="FlipCard">
                <div class="flashcard @(isFlipped ? "is-flipped" : "")">
                    
                    <div class="card-face card-front glass-card shadow-2xl">
                        <div class="absolute top-6 left-6 opacity-20"><i class="ph ph-question text-4xl text-slate-900 dark:text-white"></i></div>
                        <div class="p-8 md:p-12 text-center flex flex-col items-center justify-center h-full">
                            <h3 class="text-2xl md:text-3xl font-bold text-slate-900 dark:text-white leading-snug font-playfair italic">
                                @CurrentQuestion?.QuestionText
                            </h3>
                            <p class="mt-8 text-[9px] text-indigo-600 dark:text-indigo-400 uppercase font-bold tracking-[0.3em] animate-pulse">Klikni nebo stiskni Mezerník</p>
                        </div>
                    </div>
                    
                    <div class="card-face card-back glass-card border-indigo-200 dark:border-indigo-500/30">
                        <div class="absolute top-6 left-6 opacity-20"><i class="ph ph-info text-4xl text-indigo-600 dark:text-indigo-400"></i></div>
                        <div class="p-8 md:p-12 flex flex-col items-center justify-center h-full text-center">
                            <span class="text-[10px] font-bold text-emerald-600 dark:text-emerald-400 uppercase tracking-widest mb-4">Správná odpověď</span>
                            <h4 class="text-xl md:text-2xl font-bold text-slate-900 dark:text-white mb-6 leading-tight">
                                @GetCorrectOptionText()
                            </h4>
                            <div class="w-12 h-1 bg-slate-200 dark:bg-white/10 rounded-full mb-6"></div>
                            <p class="text-slate-600 dark:text-slate-300 text-sm leading-relaxed italic line-clamp-4">
                                @CurrentQuestion?.Explanation
                            </p>
                        </div>
                    </div>

                </div>
            </div>
            
            <div class="mt-10 flex items-center gap-6 animate-fade-in">
                <button @onclick="PrevCard" disabled="@(currentIndex == 0 || isAnimating)" 
                        class="w-14 h-14 rounded-full bg-slate-100 dark:bg-white/10 border border-slate-300 dark:border-white/10 text-slate-800 dark:text-white flex items-center justify-center hover:bg-slate-200 dark:hover:bg-white/20 transition disabled:opacity-50 disabled:cursor-not-allowed shadow-sm dark:shadow-none">
                    <i class="ph ph-caret-left text-2xl"></i>
                </button>
    
                <button @onclick="NextCard" disabled="@isAnimating"
                        class="bg-indigo-600 hover:bg-indigo-500 disabled:opacity-50 text-white px-10 py-4 rounded-2xl font-bold uppercase tracking-widest text-[11px] shadow-xl shadow-indigo-500/20 transition active:scale-95 flex items-center gap-2 disabled:cursor-not-allowed">
                    @(currentIndex < questions.Count - 1 ? "Další karta" : "Dokončit") <i class="ph ph-arrow-right"></i>
                </button>
            </div>
        }
        else if (isFinished)
        {
            <div class="glass-card max-w-md w-full rounded-[40px] p-12 text-center shadow-2xl bounce-in">
                <div class="w-20 h-20 bg-emerald-100 dark:bg-emerald-500/20 rounded-full flex items-center justify-center mx-auto mb-6">
                    <i class="ph ph-check-circle text-5xl text-emerald-500 dark:text-emerald-400"></i>
                </div>
                <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-2 tracking-tighter uppercase">Skvělá práce!</h2>
                <p class="text-slate-500 uppercase tracking-widest text-[10px] font-bold mb-6">Prošel jsi všechny vybrané kartičky</p>
                
                <div class="bg-indigo-50 dark:bg-indigo-500/10 border border-indigo-200 dark:border-indigo-500/20 rounded-2xl p-4 mb-8 flex items-center justify-center gap-3 text-indigo-700 dark:text-indigo-400">
                    <i class="ph ph-star-four text-2xl animate-pulse"></i>
                    <span class="font-bold text-lg">+@xpEarned XP</span>
                </div>

                <div class="space-y-3">
                    <button @onclick="Reset" class="w-full bg-slate-200 dark:bg-slate-800 text-slate-800 dark:text-white py-4 rounded-2xl font-bold uppercase tracking-widest text-xs transition hover:bg-slate-300 dark:hover:bg-slate-700">Zopakovat stejné</button>
                    <button @onclick="@(() => Navigation.NavigateTo("/"))" class="w-full bg-slate-200 dark:bg-slate-800 text-slate-800 dark:text-white py-4 rounded-2xl font-bold uppercase tracking-widest text-xs transition hover:bg-slate-300 dark:hover:bg-slate-700">Zpět domů</button>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .perspective-container { perspective: 1500px; }
    .flashcard { width: 100%; height: 100%; position: relative; transform-style: preserve-3d; transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1); cursor: pointer; }
    .flashcard.is-flipped { transform: rotateY(180deg); }
    .card-face { position: absolute; width: 100%; height: 100%; backface-visibility: hidden; -webkit-backface-visibility: hidden; border-radius: 40px; overflow: hidden; }
    .card-back { transform: rotateY(180deg); }
    
    .glass-card { background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(25px); -webkit-backdrop-filter: blur(25px); border: 1px solid rgba(0, 0, 0, 0.05); }
    .dark .glass-card { background: rgba(30, 41, 59, 0.45); border: 1px solid rgba(255, 255, 255, 0.1); }
    
    .animate-fade-in { animation: fadeIn 0.5s ease-out; }
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

    /* Animace pro přepínání karet */
    .animate-card-enter-right { animation: slideInRight 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; }
    .animate-card-exit-left { animation: slideOutLeft 0.25s ease-in forwards; }
    .animate-card-enter-left { animation: slideInLeft 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; }
    .animate-card-exit-right { animation: slideOutRight 0.25s ease-in forwards; }

    @@keyframes slideInRight { from { transform: translateX(100px) scale(0.9); opacity: 0; } to { transform: translateX(0) scale(1); opacity: 1; } }
    @@keyframes slideOutLeft { from { transform: translateX(0) scale(1); opacity: 1; } to { transform: translateX(-100px) scale(0.9); opacity: 0; } }
    @@keyframes slideInLeft { from { transform: translateX(-100px) scale(0.9); opacity: 0; } to { transform: translateX(0) scale(1); opacity: 1; } }
    @@keyframes slideOutRight { from { transform: translateX(0) scale(1); opacity: 1; } to { transform: translateX(100px) scale(0.9); opacity: 0; } }
</style>

@code {
    [Parameter] public string SubjectName { get; set; } = "";
    [Parameter] public string TopicName { get; set; } = "";
    [Parameter] public int? Limit { get; set; }

    private ElementReference mainContainer;
    private List<QuestionRecord> questions = new();
    private int currentIndex = 0;
    private int xpEarned = 0;
    private bool isFlipped = false;
    private bool isLoading = true;
    private bool isFinished = false;

    private string cardAnimationClass = "";
    private bool isAnimating = false;

    protected override async Task OnParametersSetAsync() => await LoadData();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await mainContainer.FocusAsync();
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (isFinished || isAnimating) return;

        switch (e.Key)
        {
            case " ":
            case "Enter":
                FlipCard();
                break;
            case "ArrowRight":
                await NextCard();
                break;
            case "ArrowLeft":
                await PrevCard();
                break;
        }
    }

    private async Task LoadData()
    {
        isLoading = true;
        try {
            var connString = Configuration.GetConnectionString("MyDb");
            using var connection = new NpgsqlConnection(connString);
            var sql = @"SELECT question_text as QuestionText, option_a as OptionA, option_b as OptionB, option_c as OptionC, option_d as OptionD, correct_option as CorrectOption, explanation as Explanation 
                        FROM learning_questions WHERE subject = @Subject AND topic = @Topic ORDER BY RANDOM()";
            
            if (Limit.HasValue && Limit.Value > 0)
            {
                sql += " LIMIT @Limit";
            }

            var result = await connection.QueryAsync<QuestionRecord>(sql, new { Subject = SubjectName, Topic = TopicName, Limit = Limit });
            questions = result.ToList();
        } catch { }
        finally { isLoading = false; StateHasChanged(); }
    }

    private QuestionRecord? CurrentQuestion => questions.ElementAtOrDefault(currentIndex);

    private void FlipCard() 
    {
        if (!isAnimating) isFlipped = !isFlipped;
    }

    private async Task NextCard()
    {
        if (isAnimating) return;

        if (currentIndex < questions.Count - 1)
        {
            isAnimating = true;
            cardAnimationClass = "animate-card-exit-left";
            StateHasChanged();
            
            await Task.Delay(250); 
            
            isFlipped = false;
            currentIndex++;
            cardAnimationClass = "animate-card-enter-right";
            StateHasChanged();

            await Task.Delay(400); 
            cardAnimationClass = "";
            isAnimating = false;
        }
        else if (currentIndex == questions.Count - 1 && isFlipped)
        {
            isAnimating = true;
            cardAnimationClass = "animate-card-exit-left";
            StateHasChanged();
            
            await Task.Delay(250);
            
            isFinished = true;
            isAnimating = false;

            // Dynamická odměna za kartičky (výchozí 5)
            int xpPerCard = await UserState.GetXpRewardAsync("xp_flashcards", 5);
            xpEarned = questions.Count * xpPerCard; 
            await UserState.AddXpAsync(xpEarned);
        }
    }

    private async Task PrevCard()
    {
        if (isAnimating) return;

        if (currentIndex > 0)
        {
            isAnimating = true;
            cardAnimationClass = "animate-card-exit-right";
            StateHasChanged();
            
            await Task.Delay(250); 
            
            isFlipped = false;
            currentIndex--;
            cardAnimationClass = "animate-card-enter-left";
            StateHasChanged();

            await Task.Delay(400); 
            cardAnimationClass = "";
            isAnimating = false;
        }
    }

    private void Reset()
    {
        currentIndex = 0;
        isFlipped = false;
        isFinished = false;
        xpEarned = 0;
        cardAnimationClass = "animate-card-enter-right";
    }

    private string GetCorrectOptionText()
    {
        if (CurrentQuestion == null) return "Nenalezeno";
        return CurrentQuestion.CorrectOption.Trim().ToUpper() switch {
            "A" => CurrentQuestion.OptionA, "B" => CurrentQuestion.OptionB, "C" => CurrentQuestion.OptionC, "D" => CurrentQuestion.OptionD, _ => "Neznámá volba"
        };
    }

    public class QuestionRecord {
        public string QuestionText { get; set; } = ""; 
        public string OptionA { get; set; } = ""; 
        public string OptionB { get; set; } = ""; 
        public string OptionC { get; set; } = ""; 
        public string OptionD { get; set; } = ""; 
        public string CorrectOption { get; set; } = ""; 
        public string Explanation { get; set; } = "";
    }
}