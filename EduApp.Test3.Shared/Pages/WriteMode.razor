@page "/write/{SubjectName}/{TopicName}"
@page "/write/{SubjectName}/{TopicName}/{Limit:int}"
@using Dapper
@using Microsoft.Data.Sqlite
@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration
@inject NavigationManager Navigation
@inject UserState UserState

<div class="fixed inset-0 z-[100] bg-slate-50 dark:bg-slate-950 flex flex-col font-outfit overflow-y-auto transition-colors duration-500">
    <!-- Pozadí -->
    <div class="fixed inset-0 z-0 pointer-events-none">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-indigo-200 dark:from-indigo-500/10 via-transparent to-transparent"></div>
    </div>

    <!-- Horní lišta -->
    <nav class="relative z-10 flex items-center justify-between p-4 md:p-6 border-b border-slate-200 dark:border-white/5 bg-white/50 dark:bg-slate-900/50 backdrop-blur-md transition-colors">
        <div class="flex items-center gap-4">
            <button @onclick='() => Navigation.NavigateTo("/")' class="w-10 h-10 rounded-full flex items-center justify-center bg-slate-200/50 dark:bg-white/5 hover:bg-slate-300/50 dark:hover:bg-white/10 text-slate-700 dark:text-white transition">
                <i class="ph ph-x text-xl"></i>
            </button>
            <div>
                <h1 class="text-slate-900 dark:text-white font-bold text-sm md:text-base uppercase tracking-tight">@SubjectName • Psaní</h1>
                <div class="flex items-center gap-2">
                    <div class="w-24 h-1.5 bg-slate-200 dark:bg-slate-800 rounded-full overflow-hidden">
                        <div class="bg-indigo-500 h-full transition-all duration-500" style="width: @GetProgress()%"></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-emerald-100 dark:bg-emerald-500/20 flex items-center justify-center text-emerald-600 dark:text-emerald-400">
                <i class="ph ph-keyboard text-xl"></i>
            </div>
        </div>
    </nav>

    <!-- Obsah -->
    <div class="relative z-10 flex-grow flex items-center justify-center p-4 md:p-8">
        <div class="w-full max-w-3xl">
            @if (isLoading)
            {
            <div class="text-center">
                <i class="ph ph-spinner animate-spin text-5xl text-indigo-500 mb-4"></i>
                <p class="text-slate-500 dark:text-slate-400 uppercase tracking-widest text-[10px]">Připravuji výzvu...</p>
            </div>
            }
            else if (!isFinished && questions.Any())
            {
            <div class="space-y-12 animate-fade-in">
                <!-- Otázka -->
                <div class="text-center space-y-4">
                    <span class="text-[10px] font-bold text-indigo-500 dark:text-indigo-400 uppercase tracking-[0.3em]">Zbývá otázek: @(questions.Count - currentIndex)</span>
                    <h2 class="text-3xl md:text-5xl font-bold text-slate-900 dark:text-white leading-tight tracking-tighter font-playfair italic px-4">
                        @CurrentQuestion?.QuestionText
                    </h2>
                </div>

                <!-- Vstupní pole -->
                <div class="relative max-w-xl mx-auto">
                    <input @bind="userInput"
                           @bind:event="oninput"
                           @onkeydown="HandleKeyDown"
                           disabled="@isAnswered"
                           autofocus
                           placeholder="Napiš svou odpověď..."
                           class="@GetInputClass()" />

                    @if (isAnswered)
                    {
                    <div class="absolute -bottom-12 left-0 right-0 text-center animate-bounce-in">
                        @if (answerStatus == AnswerStatus.Correct)
                        {
                        <span class="text-emerald-600 dark:text-emerald-400 font-bold uppercase tracking-widest text-xs flex items-center justify-center gap-2">
                            <i class="ph ph-check-circle-fill text-lg"></i> Skvěle! Přesně tak.
                        </span>
                        }
                        else if (answerStatus == AnswerStatus.Partial)
                        {
                        <span class="text-amber-600 dark:text-amber-400 font-bold uppercase tracking-widest text-xs flex items-center justify-center gap-2">
                            <i class="ph ph-warning-circle-fill text-lg"></i> Skoro! Překlep nebo neúplná odpověď. Zkus to hned znovu.
                        </span>
                        }
                        else
                        {
                        <span class="text-red-600 dark:text-red-400 font-bold uppercase tracking-widest text-xs flex items-center justify-center gap-2">
                            <i class="ph ph-x-circle-fill text-lg"></i> Vedle! Jdeme dál.
                        </span>
                        }
                    </div>
                    }
                </div>

                <!-- Nápověda / Zobrazení správné odpovědi -->
                @if (isAnswered && answerStatus != AnswerStatus.Correct)
                {
                <div class="glass-card rounded-3xl p-6 border-indigo-500/20 max-w-xl mx-auto animate-slide-up text-center">
                    <p class="text-slate-500 text-[10px] uppercase font-bold tracking-widest mb-2">Správná odpověď byla:</p>
                    <p class="text-slate-900 dark:text-white text-xl font-bold">@GetCorrectAnswerText()</p>
                    @if (!string.IsNullOrEmpty(CurrentQuestion?.Explanation))
                    {
                    <p class="text-slate-500 dark:text-slate-400 text-sm italic mt-4">@CurrentQuestion?.Explanation</p>
                    }
                </div>
                }

                <!-- Akční tlačítka -->
                <div class="flex justify-center mt-12">
                    @if (!isAnswered)
                    {
                    <button @onclick="SubmitAnswer"
                            disabled="@string.IsNullOrWhiteSpace(userInput)"
                            class="bg-indigo-600 hover:bg-indigo-500 disabled:opacity-30 text-white px-12 py-4 rounded-2xl font-bold uppercase tracking-widest text-sm shadow-xl transition active:scale-95">
                        Potvrdit (Enter)
                    </button>
                    }
                    else
                    {
                    <button @onclick="NextQuestion"
                            class="bg-slate-800 dark:bg-white text-white dark:text-slate-900 px-12 py-4 rounded-2xl font-bold uppercase tracking-widest text-sm shadow-xl transition hover:bg-slate-700 dark:hover:bg-slate-100 active:scale-95">
                        @(answerStatus == AnswerStatus.Correct ? "Pokračovat" : "Beru na vědomí")
                    </button>
                    }
                </div>
            </div>
            }
            else
            {
            <div class="glass-card max-w-md mx-auto rounded-[40px] p-12 text-center shadow-2xl bounce-in">
                <div class="w-24 h-24 bg-indigo-100 dark:bg-indigo-500/20 rounded-full flex items-center justify-center mx-auto mb-8">
                    <i class="ph ph-sparkle text-5xl text-indigo-500 dark:text-indigo-400"></i>
                </div>
                <h2 class="text-4xl font-bold text-slate-900 dark:text-white mb-2 tracking-tighter uppercase">Dokončeno!</h2>
                <p class="text-slate-500 font-bold uppercase tracking-widest text-[10px] mb-8">Ovládl jsi toto téma</p>

                <div class="flex justify-center gap-6 mb-10">
                    <div class="text-center">
                        <span class="block text-slate-500 text-[10px] font-bold uppercase tracking-widest mb-1">Skóre</span>
                        <div class="text-4xl font-bold text-slate-900 dark:text-white tracking-tighter">@score</div>
                    </div>
                    <div class="w-px bg-slate-200 dark:bg-white/10"></div>
                    <div class="text-center text-indigo-600 dark:text-indigo-400">
                        <span class="block text-[10px] font-bold uppercase tracking-widest mb-1">Zkušenosti</span>
                        <div class="text-4xl font-bold tracking-tighter">+@xpEarned</div>
                    </div>
                </div>

                <button @onclick='() => Navigation.NavigateTo("/")' class="w-full bg-slate-900 dark:bg-white text-white dark:text-slate-900 py-4 rounded-2xl font-bold uppercase tracking-widest text-xs transition shadow-lg hover:bg-slate-800 dark:hover:bg-slate-100">Zpět na nástěnku</button>
            </div>
            }
        </div>
    </div>
</div>

<style>
    .glass-card { background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(20px); border: 1px solid rgba(0, 0, 0, 0.05); }
    .dark .glass-card { background: rgba(30, 41, 59, 0.4); border: 1px solid rgba(255, 255, 255, 0.05); }

    .write-input {
        width: 100%;
        background: rgba(255, 255, 255, 0.8);
        border: 2px solid rgba(0, 0, 0, 0.1);
        border-radius: 24px;
        padding: 24px 32px;
        color: #0f172a;
        font-size: 1.5rem;
        font-weight: 700;
        text-align: center;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        outline: none;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }
    .dark .write-input {
        background: rgba(15, 23, 42, 0.6);
        border: 2px solid rgba(255, 255, 255, 0.05);
        color: white;
        box-shadow: none;
    }

    .write-input:focus { border-color: #6366f1; background: #fff; box-shadow: 0 0 30px rgba(99, 102, 241, 0.2); }
    .dark .write-input:focus { background: rgba(30, 41, 59, 0.8); box-shadow: 0 0 30px rgba(99, 102, 241, 0.1); }
    
    .write-input.correct { border-color: #10b981; background: rgba(16, 185, 129, 0.1); color: #047857; }
    .dark .write-input.correct { color: #10b981; }
    
    .write-input.partial { border-color: #fbbf24; background: rgba(251, 191, 36, 0.1); color: #b45309; }
    .dark .write-input.partial { color: #fbbf24; }
    
    .write-input.wrong { border-color: #ef4444; background: rgba(239, 68, 68, 0.1); color: #b91c1c; }
    .dark .write-input.wrong { color: #ef4444; }

    .animate-fade-in { animation: fadeIn 0.5s ease-out; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    .animate-slide-up { animation: slideUp 0.3s ease-out; }
    @@keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    .bounce-in { animation: bounceIn 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
    @@keyframes bounceIn { from { transform: scale(0.9); opacity: 0; } to { transform: scale(1); opacity: 1; } }
</style>

@code {
    [Parameter] public string SubjectName { get; set; } = "";
    [Parameter] public string TopicName { get; set; } = "";
    [Parameter] public int? Limit { get; set; }

    private enum AnswerStatus { None, Correct, Partial, Wrong }

    private List<QuestionRecord> questions = new();
    private int currentIndex = 0;
    private int initialCount = 0;
    private int score = 0;
    private int xpEarned = 0;
    private string userInput = "";
    private bool isAnswered = false;
    private AnswerStatus answerStatus = AnswerStatus.None;
    private bool isFinished = false;
    private bool isLoading = true;

    protected override async Task OnParametersSetAsync() => await LoadData();

    private async Task LoadData()
    {
        isLoading = true;
        try {
            var connString = Configuration.GetConnectionString("MyDb");
            using var connection = new SqliteConnection(connString);
            var sql = @"SELECT question_text as QuestionText, option_a as OptionA, option_b as OptionB, option_c as OptionC, option_d as OptionD, correct_option as CorrectOption, explanation 
                        FROM learning_questions WHERE subject = @Subject AND topic = @Topic ORDER BY RANDOM()";

            if (Limit.HasValue && Limit.Value > 0)
            {
                sql += " LIMIT @Limit";
            }

            var result = await connection.QueryAsync<QuestionRecord>(sql, new { Subject = SubjectName, Topic = TopicName, Limit = Limit });
            questions = result.ToList();
            initialCount = questions.Count;
        } catch { }
        finally { isLoading = false; StateHasChanged(); }
    }

    private QuestionRecord? CurrentQuestion => questions.ElementAtOrDefault(currentIndex);

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            if (!isAnswered && !string.IsNullOrWhiteSpace(userInput)) SubmitAnswer();
            else if (isAnswered) await NextQuestion();
        }
    }

    private void SubmitAnswer()
    {
        if (isAnswered || CurrentQuestion == null) return;

        var correctText = GetCorrectAnswerText();
        answerStatus = EvaluateAnswer(userInput, correctText);

        if (answerStatus == AnswerStatus.Correct) score++;

        isAnswered = true;
    }

    private AnswerStatus EvaluateAnswer(string userText, string correctText)
    {
        var normUser = Normalize(userText);
        var normCorrect = Normalize(correctText);

        if (normUser == normCorrect) return AnswerStatus.Correct;

        int distance = CalculateLevenshteinDistance(normUser, normCorrect);
        int allowedTypos = normCorrect.Length > 7 ? 2 : (normCorrect.Length > 4 ? 1 : 0);

        if (distance <= allowedTypos) return AnswerStatus.Partial;

        var userWords = normUser.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        var correctWords = normCorrect.Split(' ', StringSplitOptions.RemoveEmptyEntries);

        if (userWords.Length > 0 && userWords.All(w => correctWords.Contains(w)))
        {
            return AnswerStatus.Partial;
        }

        if (normCorrect.Contains(normUser) && normUser.Length >= 3)
        {
            return AnswerStatus.Partial;
        }

        return AnswerStatus.Wrong;
    }

    private string Normalize(string input)
    {
        if (string.IsNullOrWhiteSpace(input)) return "";
        var sb = new System.Text.StringBuilder();
        foreach (char c in input.ToLowerInvariant())
        {
            if (!char.IsPunctuation(c)) sb.Append(c);
        }
        return sb.ToString().Trim();
    }

    private int CalculateLevenshteinDistance(string source, string target)
    {
        if (string.IsNullOrEmpty(source)) return string.IsNullOrEmpty(target) ? 0 : target.Length;
        if (string.IsNullOrEmpty(target)) return source.Length;

        int[] v0 = new int[target.Length + 1];
        int[] v1 = new int[target.Length + 1];

        for (int i = 0; i < v0.Length; i++) v0[i] = i;

        for (int i = 0; i < source.Length; i++)
        {
            v1[0] = i + 1;
            for (int j = 0; j < target.Length; j++)
            {
                int cost = (source[i] == target[j]) ? 0 : 1;
                v1[j + 1] = Math.Min(Math.Min(v1[j] + 1, v0[j + 1] + 1), v0[j] + cost);
            }
            for (int j = 0; j < v0.Length; j++) v0[j] = v1[j];
        }
        return v1[target.Length];
    }

    private string GetCorrectAnswerText()
    {
        if (CurrentQuestion == null) return "";
        return CurrentQuestion.CorrectOption.Trim().ToUpper() switch {
            "A" => CurrentQuestion.OptionA,
            "B" => CurrentQuestion.OptionB,
            "C" => CurrentQuestion.OptionC,
            "D" => CurrentQuestion.OptionD,
            _ => ""
        };
    }

    private async Task NextQuestion()
    {
        if (CurrentQuestion == null) return;

        if (answerStatus == AnswerStatus.Partial)
        {
            questions.Insert(currentIndex + 1, CurrentQuestion);
        }

        if (currentIndex < questions.Count - 1)
        {
            currentIndex++;
            userInput = "";
            isAnswered = false;
            answerStatus = AnswerStatus.None;
        }
        else
        {
            isFinished = true;
            // Dynamická odměna za psaní (výchozí 15 XP za správnou)
            int xpPerWrite = await UserState.GetXpRewardAsync("xp_write", 15);
            xpEarned = score * xpPerWrite;
            await UserState.AddXpAsync(xpEarned);
        }
    }

    private string GetInputClass()
    {
        var baseClass = "write-input";
        return answerStatus switch
        {
            AnswerStatus.Correct => $"{baseClass} correct",
            AnswerStatus.Partial => $"{baseClass} partial",
            AnswerStatus.Wrong => $"{baseClass} wrong",
            _ => baseClass
        };
    }

    private int GetProgress() => initialCount > 0 ? (int)(Math.Min(1, (double)currentIndex / initialCount) * 100) : 0;

    public class QuestionRecord {
        public string QuestionText { get; set; } = "";
        public string OptionA { get; set; } = "";
        public string OptionB { get; set; } = "";
        public string OptionC { get; set; } = "";
        public string OptionD { get; set; } = "";
        public string CorrectOption { get; set; } = "";
        public string Explanation { get; set; } = "";
    }
}