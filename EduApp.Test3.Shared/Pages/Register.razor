@page "/register"
@layout AuthLayout
@using EduApp.Test3.Web.Services
@inject NavigationManager Navigation
@inject UserState UserState
@inject IEmailService EmailService

<div class="w-full max-w-md p-4 animate-fade-in relative z-10">
    <div class="text-center mb-10">
        <h1 class="text-3xl font-bold text-slate-900 dark:text-white tracking-tighter uppercase font-outfit">Vytvoř si účet</h1>
        <p class="text-slate-500 dark:text-slate-400 text-sm font-medium mt-1">Začni svou cestu k lepším výsledkům</p>
    </div>

    <div class="glass-card rounded-[32px] p-8 shadow-2xl relative">
        <div class="space-y-4">
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="bg-red-100 dark:bg-red-500/20 border border-red-200 dark:border-red-500/30 text-red-600 dark:text-red-400 px-4 py-3 rounded-xl text-xs font-bold text-center animate-bounce-in">
                    @errorMessage
                </div>
            }

            <div>
                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2 ml-1">Uživatelské jméno</label>
                <input type="text" @bind="username" class="w-full auth-input rounded-xl px-4 py-3 focus:outline-none transition" placeholder="TvojeJmeno">
            </div>
            <div>
                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2 ml-1">E-mail</label>
                <input type="email" @bind="email" class="w-full auth-input rounded-xl px-4 py-3 focus:outline-none transition" placeholder="jmeno@email.cz">
            </div>
            <div>
                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2 ml-1">Heslo</label>
                <input type="password" @bind="password" class="w-full auth-input rounded-xl px-4 py-3 focus:outline-none transition" placeholder="Minimálně 8 znaků" @onkeydown="@(async e => { if (e.Key == "Enter") await HandleRegister(); })">
            </div>
            
            <button @onclick="HandleRegister" disabled="@isLoading" class="w-full bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-bold py-4 rounded-xl transition shadow-lg uppercase tracking-widest text-xs mt-4 active:scale-95 flex items-center justify-center gap-2 hover:shadow-indigo-500/25">
                @if(isLoading) { <i class="ph ph-spinner animate-spin text-lg"></i> }
                Zaregistrovat se
            </button>
        </div>

        <div class="relative my-8 text-center">
            <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-slate-200 dark:border-white/5"></div></div>
            <span class="relative bg-slate-50 dark:bg-slate-950 px-4 text-[10px] font-bold text-slate-500 dark:text-slate-600 uppercase tracking-widest">Nebo se registruj přes</span>
        </div>

        <div class="grid grid-cols-2 gap-3">
            <button @onclick='() => ShowSocialError("Google")' disabled="@isLoading" class="social-btn flex items-center justify-center gap-2 py-3 rounded-xl transition text-[10px] font-bold uppercase tracking-widest active:scale-95">
                <i class="ph ph-google-logo text-lg text-red-500 dark:text-red-400"></i> Google
            </button>
            <button @onclick='() => ShowSocialError("Apple")' disabled="@isLoading" class="social-btn flex items-center justify-center gap-2 py-3 rounded-xl transition text-[10px] font-bold uppercase tracking-widest active:scale-95">
                <i class="ph ph-apple-logo text-lg"></i> Apple
            </button>
        </div>
    </div>

    <p class="text-center mt-8 text-sm text-slate-500">
        Už máš účet? 
        <NavLink href="login" class="text-indigo-500 dark:text-indigo-400 font-bold hover:underline">Přihlas se</NavLink>
    </p>
</div>

<!-- OVEROVACI MODAL -->
@if (showVerificationModal)
{
    <div class="fixed inset-0 z-[200] flex items-center justify-center p-4 bg-slate-900/80 backdrop-blur-md animate-fade-in">
        <div class="glass-card max-w-sm w-full rounded-[40px] p-8 text-center relative bounce-in shadow-[0_0_50px_rgba(99,102,241,0.15)]" @onclick:stopPropagation>
            
            <div class="w-16 h-16 bg-indigo-100 dark:bg-indigo-500/20 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-inner">
                <i class="ph ph-paper-plane-tilt text-3xl text-indigo-600 dark:text-indigo-400"></i>
            </div>
            
            <h3 class="text-2xl font-bold text-slate-900 dark:text-white uppercase tracking-tighter mb-2">E-mail odeslán</h3>
            <p class="text-slate-500 text-xs font-medium mb-8 leading-relaxed">
                Na adresu <strong class="text-slate-700 dark:text-slate-300">@email</strong> jsme ti poslali ověřovací kód.<br><br>
                Zadej ho sem, nebo rovnou klikni na tlačítko v e-mailu.
            </p>
            
            @if (!string.IsNullOrEmpty(modalErrorMessage))
            {
                <div class="bg-red-100 dark:bg-red-500/20 border border-red-200 dark:border-red-500/30 text-red-600 dark:text-red-400 px-4 py-3 rounded-xl text-xs font-bold text-center animate-bounce-in mb-4">
                    @modalErrorMessage
                </div>
            }

            <input type="text" @bind="inputCode" maxlength="6" class="w-full auth-input rounded-2xl px-4 py-4 text-center text-3xl font-bold tracking-[0.5em] focus:outline-none transition mb-6 shadow-inner uppercase" placeholder="000000" @onkeydown="@(async e => { if (e.Key == "Enter") await VerifyManualCode(); })" autofocus />

            <div class="space-y-3">
                <button @onclick="VerifyManualCode" disabled="@isVerifying" class="w-full bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-4 rounded-xl uppercase tracking-widest text-xs transition shadow-lg shadow-indigo-500/30 flex justify-center items-center gap-2 active:scale-95">
                    @if(isVerifying) { <i class="ph ph-spinner animate-spin text-lg"></i> }
                    Ověřit kód
                </button>
            </div>
        </div>
    </div>
}

<style>
    .glass-card { background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(20px); border: 1px solid rgba(0, 0, 0, 0.05); }
    .dark .glass-card { background: rgba(30, 41, 59, 0.4); border: 1px solid rgba(255, 255, 255, 0.05); }

    .auth-input { background: #ffffff; border: 1px solid #e2e8f0; color: #0f172a; box-shadow: 0 1px 2px rgba(0,0,0,0.05); }
    .dark .auth-input { background: rgba(15, 23, 42, 0.5); border: 1px solid rgba(255,255,255,0.1); color: #ffffff; box-shadow: none; }
    .auth-input:focus { border-color: #6366f1; }
    .dark .auth-input:focus { border-color: #818cf8; }
    
    .social-btn { background: #ffffff; border: 1px solid #e2e8f0; color: #334155; box-shadow: 0 1px 2px rgba(0,0,0,0.05); }
    .dark .social-btn { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.05); color: #ffffff; box-shadow: none; }
    .social-btn:hover { background: #f8fafc; }
    .dark .social-btn:hover { background: rgba(255,255,255,0.1); }

    .animate-fade-in { animation: fadeIn 0.4s ease-out; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    .animate-bounce-in { animation: bounceIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
    @@keyframes bounceIn { from { transform: scale(0.9); opacity: 0; } to { transform: scale(1); opacity: 1; } }
</style>

@code {
    private string username = "";
    private string email = "";
    private string password = "";
    private string errorMessage = "";
    private bool isLoading = false;

    // Logika modálu
    private bool showVerificationModal = false;
    private string generatedCode = "";
    private string inputCode = "";
    private string modalErrorMessage = "";
    private bool isVerifying = false;

    private async Task HandleRegister()
    {
        errorMessage = "";
        if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Vyplň prosím všechna pole.";
            return;
        }

        isLoading = true;
        StateHasChanged();

        // 1. Založíme v DB neověřeného uživatele a vygenerujeme kód
        generatedCode = Random.Shared.Next(100000, 999999).ToString();
        var result = await UserState.RegisterPendingUserAsync(username, email, password, generatedCode);
        
        if (!result.Success)
        {
            errorMessage = result.ErrorMessage;
            isLoading = false;
            return;
        }

        try
        {
            // 2. Vygenerujeme absolutní URL pro magický odkaz podle toho, kde to běží (localhost vs produkce)
            string baseUrl = Navigation.BaseUri;
            string magicLink = $"{baseUrl}verify?email={Uri.EscapeDataString(email)}&code={generatedCode}";

            // 3. Pošleme e-mail
            await EmailService.SendRegistrationEmailAsync(email, username, generatedCode, magicLink);
            
            // 4. Otevřeme ověřovací modál
            inputCode = "";
            modalErrorMessage = "";
            showVerificationModal = true;
        }
        catch (Exception)
        {
            errorMessage = "Uživatel vytvořen, ale nepodařilo se odeslat e-mail.";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task VerifyManualCode()
    {
        modalErrorMessage = "";
        if (string.IsNullOrWhiteSpace(inputCode))
        {
            modalErrorMessage = "Zadej kód.";
            return;
        }

        isVerifying = true;
        StateHasChanged();

        var result = await UserState.VerifyAccountAsync(email, inputCode);
        
        isVerifying = false;
        if (result.Success)
        {
            showVerificationModal = false;
            Navigation.NavigateTo("/");
        }
        else
        {
            modalErrorMessage = result.ErrorMessage;
            StateHasChanged();
        }
    }

    private void ShowSocialError(string provider)
    {
        errorMessage = $"Registrace přes {provider} zatím není napojena.";
    }
}