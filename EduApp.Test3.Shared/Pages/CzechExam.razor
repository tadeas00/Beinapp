@page "/exam/cj/{TestId}"
@using EduApp.Test3.Shared.Services
@inject NavigationManager Navigation
@inject ExamRepository ExamRepo
@inject UserState UserState

<div class="fixed inset-0 z-[100] bg-slate-50 dark:bg-slate-950 flex flex-col font-outfit overflow-hidden transition-colors duration-500">
    <div class="fixed inset-0 z-0 pointer-events-none">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-rose-200 dark:from-rose-900/10 via-slate-50 dark:via-slate-950 to-slate-50 dark:to-slate-950"></div>
    </div>

    <!-- Horní lišta -->
    <nav class="relative z-10 flex items-center justify-between p-4 md:p-6 border-b border-slate-200 dark:border-white/5 bg-white/50 dark:bg-slate-900/50 backdrop-blur-md transition-colors">
        <div class="flex items-center gap-4">
            <button @onclick="HandleClose" class="w-10 h-10 rounded-full flex items-center justify-center nav-back-btn transition">
                <i class="ph @GetHeaderIcon() text-xl"></i>
            </button>
            <div>
                <h1 class="text-slate-900 dark:text-white font-bold text-sm md:text-base uppercase tracking-tight flex items-center">
                    <span class="w-2 h-2 rounded-full @GetHeaderPulseClass() mr-2"></span> 
                    @TestId
                    @if(currentView == ViewState.ReviewTask || currentView == ViewState.ReviewGrid) {
                        <span class="hidden sm:inline-block ml-3 bg-indigo-100 dark:bg-indigo-500/20 text-indigo-700 dark:text-indigo-300 px-2 py-0.5 rounded-full text-[9px] font-bold uppercase tracking-widest border border-indigo-200 dark:border-indigo-500/30">Rozbor testu</span>
                    }
                </h1>
                <div class="flex items-center gap-2 mt-1">
                    <div class="w-32 h-1.5 bg-slate-200 dark:bg-slate-800 rounded-full overflow-hidden">
                        <div class="bg-rose-500 h-full transition-all duration-500" style="width: @(GetProgressBarWidth())%"></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="flex items-center gap-4">
            <div class="flex flex-col text-right">
                <span class="text-[10px] text-slate-500 dark:text-slate-400 font-bold uppercase tracking-widest">Skóre</span>
                <span class="text-xl font-bold text-slate-900 dark:text-white">@totalScore <span class="text-slate-400 dark:text-slate-600">/ @maxPossibleScore</span></span>
            </div>
        </div>
    </nav>

    <!-- Hlavní obsah -->
    <div class="relative z-10 flex-grow overflow-y-auto custom-scrollbar p-4 md:p-8">
        <div class="max-w-7xl mx-auto">
            
            @if ((currentView == ViewState.Exam || currentView == ViewState.ReviewTask) && CurrentTask != null)
            {
                <div class="flex flex-col xl:flex-row gap-6 animate-fade-in pb-40">
                    
                    <!-- Levé okno: Výchozí text -->
                    @if (!string.IsNullOrEmpty(CurrentTask.TextBase))
                    {
                        <div class="w-full xl:w-1/2">
                            <div class="glass-card rounded-3xl p-6 md:p-8 shadow-2xl sticky top-0 text-slate-800 dark:text-slate-200 leading-relaxed text-sm md:text-base">
                                <h3 class="text-[10px] font-bold text-rose-500 dark:text-rose-400 uppercase tracking-[0.2em] mb-4 flex items-center gap-2">
                                    <i class="ph ph-article text-lg"></i> Výchozí text k úloze
                                </h3>
                                @((MarkupString)CurrentTask.TextBase)
                            </div>
                        </div>
                    }

                    <!-- Pravé okno -->
                    <div class="w-full @GetRightPanelClass()">
                        <div class="glass-card rounded-3xl p-6 md:p-8 shadow-xl flex flex-col space-y-6">
                            
                            <!-- Hlavička úlohy -->
                            <div class="flex items-center justify-between pb-4 border-b border-slate-200 dark:border-white/5">
                                <span class="bg-rose-100 dark:bg-rose-500/10 text-rose-600 dark:text-rose-400 border border-rose-200 dark:border-rose-500/20 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest">
                                    Úloha @CurrentTask.TaskNumber
                                </span>
                                <span class="text-slate-500 text-[10px] font-bold uppercase tracking-widest">Max: @CurrentTask.MaxPoints b.</span>
                            </div>

                            <!-- Zadání -->
                            <h2 class="text-xl md:text-2xl font-bold text-slate-900 dark:text-white tracking-tight leading-snug">
                                @CurrentTask.Instruction
                            </h2>

                            <!-- VÝBĚR Z MOŽNOSTÍ -->
                            @if (CurrentTask.Category == TaskCategory.MultipleChoice)
                            {
                                <div class="grid gap-2.5">
                                    @foreach (var opt in CurrentTask.Options)
                                    {
                                        string btnClass = "exam-opt-default";
                                        string iconHtml = "";
                                        
                                        if (CurrentTask.IsEvaluated)
                                        {
                                            if (opt.Label == CurrentTask.ExpectedAnswer) {
                                                btnClass = "exam-opt-correct";
                                                iconHtml = "<i class='ph ph-check-circle-fill text-xl'></i>";
                                            }
                                            else if (opt.Label == CurrentTask.UserAnswer) {
                                                btnClass = "exam-opt-wrong";
                                                iconHtml = "<i class='ph ph-x-circle-fill text-xl'></i>";
                                            }
                                            else {
                                                btnClass = "exam-opt-disabled";
                                            }
                                        }
                                        else if (CurrentTask.UserAnswer == opt.Label)
                                        {
                                            btnClass = "exam-opt-selected";
                                        }

                                        <button @onclick="() => SelectMultipleChoice(opt.Label)" 
                                                disabled="@CurrentTask.IsEvaluated"
                                                class="w-full text-left p-3 md:p-4 rounded-xl border transition-all duration-300 flex items-center gap-3 @btnClass">
                                            <span class="w-8 h-8 rounded-lg flex items-center justify-center font-bold shrink-0 shadow-inner text-sm letter-box">@opt.Label</span>
                                            <span class="font-medium text-sm leading-snug">@opt.Text</span>
                                            <span class="ml-auto">@((MarkupString)iconHtml)</span>
                                        </button>
                                    }
                                </div>
                            }

                            <!-- PŘIŘAZOVÁNÍ -->
                            @if (CurrentTask.Category == TaskCategory.Matching)
                            {
                                <div class="space-y-4">
                                    <div class="bg-slate-100 dark:bg-slate-900/50 rounded-xl p-4 border border-slate-200 dark:border-white/5 space-y-2">
                                        @foreach (var opt in CurrentTask.Options)
                                        {
                                            <div class="flex items-start gap-2 text-xs md:text-sm">
                                                <span class="font-bold text-rose-500 dark:text-rose-400 w-5 shrink-0">@opt.Label)</span>
                                                <span class="text-slate-600 dark:text-slate-300 italic leading-snug">@opt.Text</span>
                                            </div>
                                        }
                                    </div>
                                    <div class="space-y-2">
                                        @foreach (var sub in CurrentTask.Items)
                                        {
                                            string matchStatusClass = CurrentTask.IsEvaluated ? (sub.UserAnswer == sub.ExpectedAnswer ? "correct" : "wrong") : "";
                                            <div class="match-item-card p-4 rounded-xl transition-all @matchStatusClass">
                                                <p class="text-slate-800 dark:text-white font-medium mb-3 text-sm leading-snug">@sub.Id @sub.Text</p>
                                                <div class="flex flex-wrap gap-2">
                                                    @foreach (var opt in CurrentTask.Options)
                                                    {
                                                        string mBtnClass = "match-btn-default";
                                                        if (CurrentTask.IsEvaluated) {
                                                            if (opt.Label == sub.ExpectedAnswer) mBtnClass = "match-btn-correct";
                                                            else if (opt.Label == sub.UserAnswer) mBtnClass = "match-btn-wrong";
                                                            else mBtnClass = "match-btn-disabled";
                                                        } else if (sub.UserAnswer == opt.Label) {
                                                            mBtnClass = "match-btn-selected";
                                                        }

                                                        <button @onclick="() => SelectMatching(sub, opt.Label)" 
                                                                disabled="@CurrentTask.IsEvaluated"
                                                                class="w-9 h-9 rounded-lg font-bold text-sm transition border @mBtnClass">
                                                            @opt.Label
                                                        </button>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }

                            <!-- ANO/NE -->
                            @if (CurrentTask.Category == TaskCategory.TrueFalse)
                            {
                                <div class="space-y-2">
                                    @foreach (var sub in CurrentTask.Items)
                                    {
                                        string tfContainer = CurrentTask.IsEvaluated ? (sub.UserAnswer == sub.ExpectedAnswer ? "match-item-card correct" : "match-item-card wrong") : "match-item-card";
                                        string btnAno = "tf-btn-default";
                                        string btnNe = "tf-btn-default";

                                        if (CurrentTask.IsEvaluated) {
                                            if (sub.ExpectedAnswer == "ANO") {
                                                btnAno = "tf-btn-correct";
                                                btnNe = sub.UserAnswer == "NE" ? "tf-btn-wrong" : "tf-btn-disabled";
                                            } else {
                                                btnNe = "tf-btn-correct";
                                                btnAno = sub.UserAnswer == "ANO" ? "tf-btn-wrong" : "tf-btn-disabled";
                                            }
                                        } else {
                                            if (sub.UserAnswer == "ANO") btnAno = "tf-btn-selected";
                                            if (sub.UserAnswer == "NE") btnNe = "tf-btn-selected";
                                        }

                                        <div class="p-3 md:p-4 rounded-xl flex items-center justify-between gap-4 @tfContainer">
                                            <p class="text-slate-800 dark:text-white text-sm font-medium leading-tight">@sub.Id @sub.Text</p>
                                            <div class="flex tf-wrapper rounded-lg p-1 shrink-0">
                                                <button @onclick='() => SelectTrueFalse(sub, "ANO")' disabled="@CurrentTask.IsEvaluated" class="px-4 py-2 rounded-md text-[10px] font-bold transition @btnAno">ANO</button>
                                                <button @onclick='() => SelectTrueFalse(sub, "NE")' disabled="@CurrentTask.IsEvaluated" class="px-4 py-2 rounded-md text-[10px] font-bold transition @btnNe">NE</button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            
                            @if (CurrentTask.Category == TaskCategory.Ordering)
                            {
                                <div class="space-y-4">
                                    <div class="min-h-[80px] bg-slate-100 dark:bg-slate-900/80 border-2 border-dashed border-rose-300 dark:border-rose-500/20 rounded-2xl p-4 flex flex-wrap gap-2 items-center justify-center relative">
                                        @foreach (var letter in CurrentTask.UserSequence) {
                                            <div class="w-10 h-10 rounded-xl bg-rose-500 dark:bg-rose-600 text-white font-bold flex items-center justify-center shadow-lg animate-bounce-in text-lg">@letter</div>
                                        }
                                        @if (!CurrentTask.UserSequence.Any()) { 
                                            <span class="text-slate-500 dark:text-slate-600 font-bold uppercase tracking-widest text-[10px]">Klikněte na části textu níže</span>
                                        }
                                    </div>
                                    
                                    @if(CurrentTask.IsEvaluated) {
                                        <div class="bg-slate-100 dark:bg-white/5 p-3 rounded-xl text-sm text-slate-600 dark:text-slate-300 text-center border border-slate-200 dark:border-white/5">
                                            <span class="text-[10px] text-emerald-600 dark:text-emerald-400 font-bold uppercase tracking-widest block mb-1">Správné pořadí mělo být:</span>
                                            @string.Join(" ➔ ", CurrentTask.ExpectedSequence)
                                        </div>
                                    }

                                    <div class="grid gap-2">
                                        @foreach (var opt in CurrentTask.Options) {
                                            bool isSelected = CurrentTask.UserSequence.Contains(opt.Label);
                                            string orderBtnClass = isSelected ? "opacity-30 dark:opacity-20 grayscale scale-[0.98] border-transparent dark:border-white/5" : "glass-card hover:border-rose-400 dark:hover:border-rose-500/50 hover:bg-slate-50 dark:hover:bg-slate-800/40";
                                            
                                            <button @onclick="() => SelectOrdering(opt.Label)"
                                                    disabled="@(isSelected || CurrentTask.IsEvaluated)"
                                                    class="text-left p-3 md:p-4 rounded-xl border transition-all @orderBtnClass">
                                                <div class="flex gap-3 items-start">
                                                    <span class="w-7 h-7 rounded-md bg-rose-100 dark:bg-rose-500/10 border border-rose-200 dark:border-rose-500/20 flex items-center justify-center font-bold text-rose-600 dark:text-rose-400 shrink-0 text-sm mt-0.5">@opt.Label</span>
                                                    <span class="text-slate-700 dark:text-slate-300 text-sm leading-snug">@opt.Text</span>
                                                </div>
                                            </button>
                                        }
                                    </div>
                                    @if(CurrentTask.UserSequence.Any() && !CurrentTask.IsEvaluated) {
                                        <button @onclick="ClearOrdering" class="text-rose-500 dark:text-rose-400 font-bold text-[10px] uppercase tracking-widest hover:text-rose-600 dark:hover:text-rose-300 flex items-center justify-center gap-1 w-full"><i class="ph ph-trash"></i> Resetovat pořadí</button>
                                    }
                                </div>
                            }

                            <!-- DOPLŇOVÁNÍ / OPRAVA -->
                            @if (CurrentTask.Category == TaskCategory.Correction || CurrentTask.Category == TaskCategory.Filling)
                            {
                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                                    @for (int i = 0; i < CurrentTask.InputFieldsCount; i++)
                                    {
                                        if (CurrentTask.UserInputs != null && i < CurrentTask.UserInputs.Length)
                                        {
                                            int idx = i;
                                            bool isCorrect = false;
                                            
                                            if (CurrentTask.IsEvaluated) {
                                                string norm = CurrentTask.UserInputs[idx]?.Trim().ToLower() ?? "";
                                                if (CurrentTask.Category == TaskCategory.Correction) {
                                                    isCorrect = CurrentTask.ExpectedSequence.Contains(norm);
                                                } else {
                                                    string[] exp = CurrentTask.ExpectedInputs[idx].ToLower().Split('/');
                                                    isCorrect = exp.Contains(norm);
                                                }
                                            }

                                            string inputClass = CurrentTask.IsEvaluated 
                                                ? (isCorrect ? "exam-input-correct" : "exam-input-wrong") 
                                                : "exam-input-default";
                                                
                                            string correctionIcon = isCorrect ? "ph-check text-emerald-500 dark:text-emerald-400" : "ph-x text-red-500 dark:text-red-400";

                                            <div class="relative group">
                                                <input @bind="CurrentTask.UserInputs[idx]" 
                                                       disabled="@CurrentTask.IsEvaluated"
                                                       placeholder="Vaše odpověď..."
                                                       class="w-full border rounded-xl px-4 py-3 text-sm font-bold transition focus:outline-none @inputClass shadow-sm dark:shadow-inner" />
                                                @if(CurrentTask.IsEvaluated) {
                                                    <i class="ph @correctionIcon absolute right-4 top-1/2 -translate-y-1/2 text-lg"></i>
                                                }
                                            </div>
                                        }
                                    }
                                </div>
                                @if(CurrentTask.IsEvaluated) {
                                    <div class="bg-slate-100 dark:bg-white/5 p-4 rounded-xl text-sm text-slate-700 dark:text-slate-300 border border-slate-200 dark:border-white/5">
                                        <span class="text-[10px] text-emerald-600 dark:text-emerald-400 font-bold uppercase tracking-widest block mb-1">Správná řešení:</span>
                                        @string.Join(", ", CurrentTask.ExpectedSequence.Any() ? CurrentTask.ExpectedSequence : CurrentTask.ExpectedInputs)
                                    </div>
                                }
                            }

                            <!-- ZÁVĚREČNÉ VYSVĚTLENÍ -->
                            @if (CurrentTask.IsEvaluated && !string.IsNullOrEmpty(CurrentTask.Explanation))
                            {
                                <div class="bg-emerald-50 dark:bg-emerald-500/5 p-5 md:p-6 rounded-2xl border border-emerald-200 dark:border-emerald-500/20 animate-slide-up shadow-lg mt-4">
                                    <div class="flex items-center gap-3 mb-3">
                                        <div class="w-6 h-6 rounded-full bg-emerald-100 dark:bg-emerald-500/20 flex items-center justify-center text-emerald-600 dark:text-emerald-400">
                                            <i class="ph ph-lightbulb-filament text-sm"></i>
                                        </div>
                                        <h4 class="text-[10px] font-bold text-emerald-600 dark:text-emerald-400 uppercase tracking-[0.2em]">Komentář a vysvětlení</h4>
                                    </div>
                                    <p class="text-slate-700 dark:text-slate-200 text-sm leading-relaxed italic">@CurrentTask.Explanation</p>
                                </div>
                            }

                        </div>
                    </div>
                </div>

                <!-- Fixní spodní lišta pro Zkoušku i Prohlížení -->
                <div class="fixed bottom-0 left-0 right-0 p-5 md:p-6 bg-white/90 dark:bg-slate-950/90 backdrop-blur-2xl border-t border-slate-200 dark:border-white/10 flex items-center justify-between z-[60] transition-colors">
                    @if (currentView == ViewState.Exam)
                    {
                        <div class="flex items-center gap-4">
                            @if (CurrentTask.IsEvaluated) {
                                string resultColor = CurrentTask.EarnedPoints > 0 ? "text-emerald-600 dark:text-emerald-400" : "text-rose-600 dark:text-rose-400";
                                <div class="bg-slate-100 dark:bg-white/5 px-4 py-2 md:px-5 md:py-3 rounded-2xl border border-slate-200 dark:border-white/10 flex items-center gap-3">
                                    <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest hidden sm:inline">Výsledek úlohy:</span>
                                    <span class="text-lg md:text-xl font-bold @resultColor">@CurrentTask.EarnedPoints / @CurrentTask.MaxPoints b</span>
                                </div>
                            }
                        </div>
                        
                        <div class="flex gap-4">
                            @if (!CurrentTask.IsEvaluated) {
                                <button @onclick="EvaluateTask" class="bg-rose-600 hover:bg-rose-500 text-white px-8 md:px-12 py-3 md:py-4 rounded-xl md:rounded-2xl font-bold uppercase tracking-widest text-xs shadow-xl transition active:scale-95 flex items-center gap-2">
                                    <i class="ph ph-check-bold"></i> Zkontrolovat
                                </button>
                            } else {
                                <button @onclick="NextTask" class="nav-next-btn px-8 md:px-12 py-3 md:py-4 rounded-xl md:rounded-2xl font-bold uppercase tracking-widest text-xs shadow-xl transition active:scale-95 flex items-center gap-2">
                                    <span>@(currentTaskIndex < tasks.Count - 1 ? "Další úloha" : "Ukončit test")</span>
                                    <i class="ph ph-arrow-right-bold"></i>
                                </button>
                            }
                        </div>
                    }
                    else if (currentView == ViewState.ReviewTask)
                    {
                        <div class="flex items-center gap-4">
                            @{ string reviewResultColor = CurrentTask.EarnedPoints == CurrentTask.MaxPoints ? "text-emerald-600 dark:text-emerald-400" : CurrentTask.EarnedPoints > 0 ? "text-amber-600 dark:text-amber-400" : "text-rose-600 dark:text-rose-400"; }
                            <div class="bg-slate-100 dark:bg-white/5 px-4 py-2 md:px-5 md:py-3 rounded-2xl border border-slate-200 dark:border-white/10 flex items-center gap-3">
                                <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest hidden sm:inline">Výsledek úlohy:</span>
                                <span class="text-lg md:text-xl font-bold @reviewResultColor">@CurrentTask.EarnedPoints / @CurrentTask.MaxPoints b</span>
                            </div>
                        </div>
                        
                        <div class="flex gap-2 sm:gap-4 w-full md:w-auto justify-end">
                            <button @onclick="() => { if(currentTaskIndex > 0) currentTaskIndex--; }" disabled="@(currentTaskIndex == 0)" class="nav-btn p-3 md:px-6 md:py-3 rounded-xl md:rounded-2xl font-bold uppercase tracking-widest text-xs shadow-md transition disabled:opacity-30 disabled:cursor-not-allowed flex items-center gap-2">
                                <i class="ph ph-arrow-left-bold text-lg md:text-sm"></i> <span class="hidden md:inline">Předchozí</span>
                            </button>
                            <button @onclick="() => currentView = ViewState.ReviewGrid" class="bg-indigo-600 hover:bg-indigo-500 text-white px-5 md:px-8 py-3 rounded-xl md:rounded-2xl font-bold uppercase tracking-widest text-xs shadow-xl transition active:scale-95 flex items-center gap-2">
                                <i class="ph ph-grid-four text-lg md:text-sm"></i> <span class="hidden sm:inline">Přehled</span>
                            </button>
                            <button @onclick="() => { if(currentTaskIndex < tasks.Count - 1) currentTaskIndex++; }" disabled="@(currentTaskIndex == tasks.Count - 1)" class="nav-btn p-3 md:px-6 md:py-3 rounded-xl md:rounded-2xl font-bold uppercase tracking-widest text-xs shadow-md transition disabled:opacity-30 disabled:cursor-not-allowed flex items-center gap-2">
                                <span class="hidden md:inline">Další</span> <i class="ph ph-arrow-right-bold text-lg md:text-sm"></i>
                            </button>
                        </div>
                    }
                </div>
            }
            else if (currentView == ViewState.Summary)
            {
                <!-- SHRNUTÍ -->
                <div class="glass-card max-w-2xl mx-auto rounded-[40px] p-8 md:p-12 text-center shadow-2xl bounce-in mt-10">
                    <div class="w-24 h-24 bg-rose-100 dark:bg-rose-500/20 rounded-full flex items-center justify-center mx-auto mb-8 shadow-[0_0_30px_rgba(244,63,94,0.1)] dark:shadow-[0_0_30px_rgba(244,63,94,0.2)]">
                        <i class="ph ph-trophy text-6xl text-rose-500"></i>
                    </div>
                    <h2 class="text-4xl md:text-5xl font-bold text-slate-900 dark:text-white mb-2 tracking-tighter uppercase font-playfair italic">Test Dokončen</h2>
                    <p class="text-slate-500 font-bold uppercase tracking-widest text-xs mb-10">Simulace @TestId</p>
                    
                    <div class="bg-slate-100 dark:bg-slate-900/50 border border-slate-200 dark:border-white/5 rounded-3xl p-8 md:p-10 mb-8">
                        <span class="text-[10px] font-bold text-slate-500 uppercase tracking-[0.3em] block mb-2">Celkové hodnocení</span>
                        <div class="text-6xl md:text-8xl font-bold text-slate-900 dark:text-white tracking-tighter">@totalScore <span class="text-2xl md:text-3xl text-slate-400 dark:text-slate-700">/ @maxPossibleScore b</span></div>
                    </div>

                    <div class="bg-emerald-50 dark:bg-emerald-500/10 border border-emerald-200 dark:border-emerald-500/20 rounded-2xl p-4 mb-10 flex items-center justify-center gap-3 text-emerald-700 dark:text-emerald-400">
                        <i class="ph ph-star-four text-2xl animate-pulse"></i>
                        <span class="font-bold text-lg">+@xpEarned XP Získáno</span>
                    </div>
                    
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <button @onclick='() => currentView = ViewState.ReviewGrid' class="w-full bg-indigo-600 hover:bg-indigo-500 text-white py-4 rounded-2xl font-bold uppercase tracking-widest text-xs transition shadow-xl active:scale-95 flex items-center justify-center gap-2">
                            <i class="ph ph-magnifying-glass text-lg"></i> Detailní rozbor
                        </button>
                        <button @onclick='() => Navigation.NavigateTo("/")' class="w-full nav-next-btn py-4 rounded-2xl font-bold uppercase tracking-widest text-xs transition shadow-xl active:scale-95 flex items-center justify-center gap-2">
                            <i class="ph ph-house text-lg"></i> Hlavní menu
                        </button>
                    </div>
                </div>
            }
            else if (currentView == ViewState.ReviewGrid)
            {
                <!-- MŘÍŽKA S PŘEHLEDEM VÝSLEDKŮ -->
                <div class="max-w-5xl mx-auto py-4 md:py-8 animate-fade-in pb-20">
                    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-8 gap-4">
                        <div>
                            <h2 class="text-3xl font-bold text-slate-900 dark:text-white uppercase tracking-tighter">Rozbor testu</h2>
                            <p class="text-slate-500 dark:text-slate-400 font-medium text-sm mt-1">Kliknutím na úlohu zobrazíte detailní řešení a vaše odpovědi.</p>
                        </div>
                        <button @onclick="() => currentView = ViewState.Summary" class="nav-back-btn px-6 py-3 rounded-xl font-bold uppercase tracking-widest text-xs transition flex items-center gap-2 shrink-0">
                            <i class="ph ph-arrow-left text-lg"></i> Zpět na skóre
                        </button>
                    </div>

                    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
                        @for (int i = 0; i < tasks.Count; i++)
                        {
                            var task = tasks[i];
                            int idx = i;
                            var isPerfect = task.EarnedPoints == task.MaxPoints;
                            var isPartial = task.EarnedPoints > 0 && task.EarnedPoints < task.MaxPoints;
                            
                            string cardClass = isPerfect ? "border-emerald-200 bg-emerald-50 hover:bg-emerald-100 dark:border-emerald-500/30 dark:bg-emerald-500/10 dark:hover:bg-emerald-500/20 text-emerald-700 dark:text-emerald-400" :
                                               isPartial ? "border-amber-200 bg-amber-50 hover:bg-amber-100 dark:border-amber-500/30 dark:bg-amber-500/10 dark:hover:bg-amber-500/20 text-amber-700 dark:text-amber-400" :
                                                           "border-rose-200 bg-rose-50 hover:bg-rose-100 dark:border-rose-500/30 dark:bg-rose-500/10 dark:hover:bg-rose-500/20 text-rose-700 dark:text-rose-400";
                            
                            string gridIcon = isPerfect ? "ph-check-circle-fill" : isPartial ? "ph-warning-fill" : "ph-x-circle-fill";

                            <button @onclick="() => GoToReviewTask(idx)" class="rounded-2xl p-4 border @cardClass flex flex-col items-center justify-center gap-2 transition-all duration-300 hover:scale-105 hover:shadow-lg relative overflow-hidden group">
                                <span class="text-[10px] font-bold uppercase tracking-widest opacity-70">Úloha @task.TaskNumber</span>
                                <i class="ph @gridIcon text-3xl mb-1"></i>
                                <span class="text-sm font-bold">@task.EarnedPoints / @task.MaxPoints b</span>
                                
                                <div class="absolute inset-0 bg-black/5 dark:bg-white/5 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center backdrop-blur-[2px]">
                                    <span class="text-[10px] font-bold uppercase tracking-widest text-slate-900 dark:text-white drop-shadow-md">Detail</span>
                                </div>
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

