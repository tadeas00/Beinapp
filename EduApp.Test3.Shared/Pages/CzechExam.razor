@code {
    [Parameter] public string TestId { get; set; } = "";

    private enum ViewState { Exam, Summary, ReviewGrid, ReviewTask }
    
    private List<CermatTask> tasks = new();
    private int currentTaskIndex = 0;
    private int totalScore = 0;
    private int xpEarned = 0;
    private int maxPossibleScore = 0;
    private ViewState currentView = ViewState.Exam;

    private CermatTask CurrentTask => tasks.ElementAtOrDefault(currentTaskIndex);

    // --- Pomocné metody pro HTML atributy k odstranění chyb Razor parseru ---
    private string GetHeaderIcon() => currentView == ViewState.ReviewTask || currentView == ViewState.ReviewGrid ? "ph-arrow-left" : "ph-x";
    private string GetHeaderPulseClass() => currentView == ViewState.Exam ? "bg-rose-500 animate-pulse" : "bg-indigo-500";
    private string GetRightPanelClass() => string.IsNullOrEmpty(CurrentTask?.TextBase) ? "max-w-3xl mx-auto" : "xl:w-1/2";
    
    private int GetProgressBarWidth() {
        if (currentView == ViewState.Summary || currentView == ViewState.ReviewGrid) return 100;
        return tasks.Any() ? (currentTaskIndex * 100) / tasks.Count : 0;
    }

    // --- Interakce odstraněny z inline HTML k zamezení Razor "div" chyb ---
    private void SelectMultipleChoice(string label) {
        if (!CurrentTask.IsEvaluated) CurrentTask.UserAnswer = label;
    }
    
    private void SelectMatching(SubItem sub, string label) {
        if (!CurrentTask.IsEvaluated) sub.UserAnswer = label;
    }

    private void SelectTrueFalse(SubItem sub, string val) {
        if (!CurrentTask.IsEvaluated) sub.UserAnswer = val;
    }

    private void SelectOrdering(string label) {
        if (!CurrentTask.UserSequence.Contains(label) && !CurrentTask.IsEvaluated) {
            CurrentTask.UserSequence.Add(label);
        }
    }
    
    private void ClearOrdering() {
        if (!CurrentTask.IsEvaluated) CurrentTask.UserSequence.Clear();
    }

    protected override void OnInitialized()
    {
        tasks = ExamRepo.GetTest(TestId);
        
        foreach (var t in tasks)
        {
            if ((t.Category == TaskCategory.Correction || t.Category == TaskCategory.Filling) && t.InputFieldsCount > 0)
            {
                if (t.UserInputs == null || t.UserInputs.Length < t.InputFieldsCount)
                {
                    t.UserInputs = new string[t.InputFieldsCount];
                    for(int i = 0; i < t.InputFieldsCount; i++) t.UserInputs[i] = "";
                }
            }
        }

        maxPossibleScore = tasks.Sum(t => t.MaxPoints);
    }

    private void EvaluateTask()
    {
        if (CurrentTask == null || CurrentTask.IsEvaluated) return;
        CurrentTask.IsEvaluated = true;
        int points = 0;

        switch (CurrentTask.Category)
        {
            case TaskCategory.MultipleChoice:
                if (CurrentTask.UserAnswer == CurrentTask.ExpectedAnswer) points = 1;
                break;

            case TaskCategory.Matching:
                foreach (var itm in CurrentTask.Items) if (itm.UserAnswer == itm.ExpectedAnswer) points++;
                break;

            case TaskCategory.TrueFalse:
                int correctCount = CurrentTask.Items.Count(i => i.UserAnswer == i.ExpectedAnswer);
                if (correctCount == 4) points = 2;
                else if (correctCount == 3) points = 1;
                break;

            case TaskCategory.Ordering:
                if (string.Join("", CurrentTask.UserSequence) == string.Join("", CurrentTask.ExpectedSequence)) points = 3;
                break;

            case TaskCategory.Correction:
                if (CurrentTask.UserInputs != null) 
                {
                    int matched = 0;
                    var usedAnswers = new HashSet<string>();
                    int emptyCount = 0;
                    
                    foreach (var ans in CurrentTask.UserInputs) {
                        string norm = ans?.Trim().ToLower() ?? "";
                        if (string.IsNullOrEmpty(norm)) { emptyCount++; continue; }
                        if (CurrentTask.ExpectedSequence.Contains(norm) && !usedAnswers.Contains(norm)) {
                            matched++; usedAnswers.Add(norm);
                        }
                    }
                    int missing = CurrentTask.ExpectedSequence.Count - matched;
                    int wrongInputs = CurrentTask.UserInputs.Length - emptyCount - matched;
                    int totalErrors = missing + wrongInputs;
                    points = Math.Max(0, CurrentTask.MaxPoints - totalErrors);
                }
                break;

            case TaskCategory.Filling:
                if (CurrentTask.UserInputs != null && CurrentTask.ExpectedInputs != null)
                {
                    for (int i = 0; i < CurrentTask.InputFieldsCount; i++) {
                        if (i < CurrentTask.UserInputs.Length && i < CurrentTask.ExpectedInputs.Length) 
                        {
                            string normUser = CurrentTask.UserInputs[i]?.Trim().ToLower() ?? "";
                            string[] expectedOptions = CurrentTask.ExpectedInputs[i].ToLower().Split('/'); 
                            if (expectedOptions.Contains(normUser)) points++;
                        }
                    }
                }
                break;
        }

        CurrentTask.EarnedPoints = Math.Min(points, CurrentTask.MaxPoints);
        totalScore += CurrentTask.EarnedPoints;
    }

    private async Task NextTask()
    {
        if (currentTaskIndex < tasks.Count - 1) currentTaskIndex++;
        else {
            currentView = ViewState.Summary;
            
            int xpPerPoint = await UserState.GetXpRewardAsync("xp_exam", 5);
            xpEarned = totalScore * xpPerPoint;
            await UserState.AddXpAsync(xpEarned);
        }
    }

    private void GoToReviewTask(int index)
    {
        currentTaskIndex = index;
        currentView = ViewState.ReviewTask;
    }

    private void HandleClose()
    {
        if (currentView == ViewState.ReviewTask) currentView = ViewState.ReviewGrid;
        else if (currentView == ViewState.ReviewGrid) currentView = ViewState.Summary;
        else Navigation.NavigateTo("/");
    }
}