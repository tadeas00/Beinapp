@page "/"
@inject NavigationManager Navigation
@inject UserState UserState

<div class="max-w-7xl mx-auto space-y-10 pb-20 relative animate-fade-in">
    
    <!-- Bento Grid - Statistiky a uvítání -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 auto-rows-[180px]">
        <div class="md:col-span-2 md:row-span-2 glass-card rounded-[40px] p-10 flex flex-col justify-between relative overflow-hidden group shadow-2xl border-indigo-200 dark:border-indigo-500/20 shadow-indigo-500/5">
            <div class="absolute top-0 right-0 p-10 opacity-10 group-hover:scale-110 transition-all duration-700">
                <i class="ph ph-sparkle text-[180px] text-indigo-500 dark:text-indigo-400"></i>
            </div>
            <div class="z-10">
                <span class="bg-indigo-100 dark:bg-indigo-500/20 text-indigo-700 dark:text-indigo-300 px-4 py-1.5 rounded-full text-[10px] font-bold uppercase tracking-widest border border-indigo-200 dark:border-indigo-500/30">Vítej zpět</span>
                <h2 class="text-4xl md:text-5xl font-bold text-slate-900 dark:text-white tracking-tighter mt-6 leading-[1.1]">Dnes tě čeká <br/><span class="text-indigo-600 dark:text-indigo-400">progres</span> v Biologii.</h2>
            </div>
            <button @onclick='() => Layout.StartSelection("Biologie")' class="z-10 w-fit start-btn px-8 py-4 rounded-2xl font-bold text-sm uppercase tracking-widest transition active:scale-95 shadow-xl">Začít se učit</button>
        </div>

        <div class="glass-card rounded-[32px] p-6 flex flex-col justify-center items-center text-center">
            <i class="ph ph-fire text-3xl text-orange-500 mb-4"></i>
            <p class="text-3xl font-bold text-slate-900 dark:text-white">@UserState.Streak</p>
            <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Streak</p>
        </div>
        <div class="glass-card rounded-[32px] p-6 flex flex-col justify-center items-center text-center relative overflow-hidden">
            <div class="absolute bottom-0 left-0 w-full h-1 bg-slate-200 dark:bg-slate-800">
                <div class="h-full bg-amber-500 transition-all duration-500" style="width: @((UserState.XpProgress * 100) / Math.Max(1, UserState.XpRequired))%"></div>
            </div>
            <i class="ph ph-crown text-3xl text-amber-500 mb-4"></i>
            <p class="text-3xl font-bold text-slate-900 dark:text-white">@UserState.Level</p>
            <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Level</p>
        </div>
        <div class="glass-card rounded-[32px] p-6 flex flex-col justify-between hover:border-slate-300 dark:hover:border-white/20 transition cursor-pointer">
             <i class="ph ph-magnifying-glass text-2xl text-slate-400"></i>
             <h4 class="text-slate-900 dark:text-white font-bold text-sm uppercase leading-tight">Hledat</h4>
        </div>
        <div class="glass-card rounded-[32px] p-6 flex flex-col justify-between hover:border-slate-300 dark:hover:border-white/20 transition cursor-pointer">
             <i class="ph ph-calendar text-2xl text-indigo-500 dark:text-indigo-400"></i>
             <h4 class="text-slate-900 dark:text-white font-bold text-sm uppercase leading-tight">Plán</h4>
        </div>
    </div>

    <!-- Sekce Předměty -->
    <section class="space-y-6">
        <h3 class="text-xl font-bold text-slate-900 dark:text-white uppercase tracking-tighter px-2">Vyber si předmět</h3>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
            <!-- Speciální Český jazyk (Volá Layout) -->
            <button @onclick='() => Layout.StartExamSelectionCZ()' class="subject-btn group border-red-200 dark:border-red-500/20 hover:border-red-400 dark:hover:border-red-500/50 relative overflow-hidden">
                <div class="absolute -right-4 -top-4 w-16 h-16 bg-red-200 dark:bg-red-500/10 rounded-full blur-xl group-hover:bg-red-300 dark:group-hover:bg-red-500/20 transition"></div>
                <div class="subject-icon bg-red-100 dark:bg-red-500/10 text-red-500 dark:text-red-400 relative z-10"><i class="ph ph-books"></i></div>
                <div class="relative z-10 mt-3">
                    <span class="block text-red-900 dark:text-red-100 font-bold text-sm md:text-base uppercase tracking-wide">Český jazyk</span>
                    <p class="text-[10px] md:text-xs text-red-600 dark:text-red-400/70 normal-case font-normal mt-1">Přijímačky & Maturita</p>
                </div>
            </button>
            
            <button @onclick='() => Layout.StartExamSelectionAJ()' class="subject-btn group border-sky-200 dark:border-sky-500/20 hover:border-sky-400 dark:hover:border-sky-500/50 relative overflow-hidden">
                <div class="absolute -right-4 -top-4 w-16 h-16 bg-sky-200 dark:bg-sky-500/10 rounded-full blur-xl group-hover:bg-sky-300 dark:group-hover:bg-sky-500/20 transition"></div>
                <div class="subject-icon bg-sky-100 dark:bg-sky-500/10 text-sky-500 dark:text-sky-400 relative z-10"><i class="ph ph-books"></i></div>
                <div class="relative z-10 mt-3">
                    <span class="block text-sky-900 dark:text-sky-100 font-bold text-sm md:text-base uppercase tracking-wide">Angličtina</span>
                    <p class="text-[10px] md:text-xs text-sky-600 dark:text-sky-400/70 normal-case font-normal mt-1">Maturita</p>
                </div>
            </button>
            
            <button @onclick='() => Layout.StartExamSelectionMAT()' class="subject-btn group border-blue-200 dark:border-blue-500/20 hover:border-blue-400 dark:hover:border-blue-500/50 relative overflow-hidden">
                <div class="absolute -right-4 -top-4 w-16 h-16 bg-blue-200 dark:bg-blue-500/10 rounded-full blur-xl group-hover:bg-blue-300 dark:group-hover:bg-blue-500/20 transition"></div>
                <div class="subject-icon bg-blue-100 dark:bg-blue-500/10 text-blue-500 dark:text-blue-400 relative z-10"><i class="ph ph-math-operations"></i></div>
                <div class="relative z-10 mt-3">
                    <span class="block text-blue-900 dark:text-blue-100 font-bold text-sm md:text-base uppercase tracking-wide">Matematika</span>
                    <p class="text-[10px] md:text-xs text-blue-600 dark:text-blue-400/70 normal-case font-normal mt-1">Přijímačky & Maturita</p>
                </div>
            </button>

            <button @onclick='() => Layout.StartSelection("Biologie")' class="subject-btn group">
                <div class="subject-icon bg-green-100 dark:bg-green-500/10 text-green-500 dark:text-green-400"><i class="ph ph-dna"></i></div>
                <div class="mt-3">
                    <span class="block text-slate-900 dark:text-white font-bold text-sm md:text-base uppercase tracking-wide">Biologie</span>
                    <p class="text-[10px] md:text-xs text-slate-500 normal-case font-normal mt-1">Studium života</p>
                </div>
            </button>

            <button @onclick='() => Layout.StartSelection("Chemie")' class="subject-btn group">
                <div class="subject-icon bg-orange-100 dark:bg-orange-500/10 text-orange-500 dark:text-orange-400"><i class="ph ph-atom"></i></div>
                <div class="mt-3">
                    <span class="block text-slate-900 dark:text-white font-bold text-sm md:text-base uppercase tracking-wide">Chemie</span>
                    <p class="text-[10px] md:text-xs text-slate-500 normal-case font-normal mt-1">Materiální svět</p>
                </div>
            </button>

            <button @onclick='() => Layout.StartSelection("Fyzika")' class="subject-btn group">
                <div class="subject-icon bg-violet-100 dark:bg-violet-500/10 text-violet-500 dark:text-violet-400"><i class="ph ph-magnet"></i></div>
                <div class="mt-3">
                    <span class="block text-slate-900 dark:text-white font-bold text-sm md:text-base uppercase tracking-wide">Fyzika</span>
                    <p class="text-[10px] md:text-xs text-slate-500 normal-case font-normal mt-1">Zákony života</p>
                </div>
            </button>

            <button @onclick='() => Layout.StartSelection("ZSV")' class="subject-btn group">
                <div class="subject-icon bg-yellow-100 dark:bg-yellow-500/10 text-yellow-500 dark:text-yellow-400"><i class="ph ph-chats-circle"></i></div>
                <div class="mt-3">
                    <span class="block text-slate-900 dark:text-white font-bold text-sm md:text-base uppercase tracking-wide">ZSV</span>
                    <p class="text-[10px] md:text-xs text-slate-500 normal-case font-normal mt-1">Základy společenských věd</p>
                </div>
            </button>
            
            <button @onclick='() => Layout.StartSelection("IT")' class="subject-btn group">
                <div class="subject-icon bg-slate-100 dark:bg-slate-500/10 text-slate-500 dark:text-slate-400"><i class="ph ph-code"></i></div>
                <div class="mt-3">
                    <span class="block text-slate-900 dark:text-white font-bold text-sm md:text-base uppercase tracking-wide">IT</span>
                    <p class="text-[10px] md:text-xs text-slate-500 normal-case font-normal mt-1">Počítačový svět</p>
                </div>
            </button>
            
            <button @onclick='() => Layout.StartSelection("Finance")' class="subject-btn group">
                <div class="subject-icon bg-teal-100 dark:bg-teal-500/10 text-teal-500 dark:text-teal-400"><i class="ph ph-credit-card"></i></div>
                <div class="mt-3">
                    <span class="block text-slate-900 dark:text-white font-bold text-sm md:text-base uppercase tracking-wide">Finanční gramotnost</span>
                    <p class="text-[10px] md:text-xs text-slate-500 normal-case font-normal mt-1">Všichni máme rádi peníze</p>
                </div>
            </button>
            
            <button @onclick='() => Layout.StartSelection("PP")' class="subject-btn group">
                <div class="subject-icon bg-rose-100 dark:bg-rose-500/10 text-rose-500 dark:text-rose-400"><i class="ph ph-first-aid"></i></div>
                <div class="mt-3">
                    <span class="block text-slate-900 dark:text-white font-bold text-sm md:text-base uppercase tracking-wide">První pomoc</span>
                    <p class="text-[10px] md:text-xs text-slate-500 normal-case font-normal mt-1">Zachraň život!</p>
                </div>
            </button>
        </div>
    </section>
</div>

<style>
    .glass-card { background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(20px); border: 1px solid rgba(0, 0, 0, 0.05); }
    .dark .glass-card { background: rgba(30, 41, 59, 0.45); border: 1px solid rgba(255, 255, 255, 0.05); }
    
    .start-btn { background: #0f172a; color: #fff; }
    .dark .start-btn { background: #fff; color: #0f172a; }
    .start-btn:hover { background: #1e293b; }
    .dark .start-btn:hover { background: #f8fafc; }

    .subject-btn { background: rgba(255, 255, 255, 0.6); border: 1px solid rgba(0, 0, 0, 0.05); padding: 24px; border-radius: 32px; transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); display: flex; flex-direction: column; justify-content: space-between; align-items: flex-start; width: 100%; aspect-ratio: 1 / 1; text-align: left; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02); }
    .dark .subject-btn { background: rgba(30, 41, 59, 0.3); border: 1px solid rgba(255, 255, 255, 0.05); box-shadow: none; }
    .subject-btn:hover { transform: translateY(-6px); border-color: rgba(99, 102, 241, 0.3); background: rgba(255, 255, 255, 0.9); box-shadow: 0 20px 40px -15px rgba(99, 102, 241, 0.15); }
    .dark .subject-btn:hover { border-color: rgba(99, 102, 241, 0.4); background: rgba(30, 41, 59, 0.5); }
    
    .subject-icon { width: 48px; height: 48px; border-radius: 14px; display: flex; align-items: center; justify-content: center; }
    .subject-btn i { font-size: 28px; transition: transform 0.4s; }
    .subject-btn:hover i { transform: scale(1.15) rotate(5deg); }
    
    .animate-fade-in { animation: fadeIn 0.4s ease-out; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
</style>

@code {
    [CascadingParameter] 
    public MainLayout Layout { get; set; } = default!;
}